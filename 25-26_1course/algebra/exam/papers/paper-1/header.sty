\newcommand{\D}{\Delta}                              % Теперь \D даст треугольник
\newcommand{\implunder}[1]{\xRightarrow[#1]{}}          % Стрелка следовательно с подписью снизу
\newcommand{\tounder}[1]{\xrightarrow[#1]{}}         % Стрелка одинарная с подписью снизу
\providecommand{\Union}[2]{\bigcup\limits_{#1}^{#2}}    % Большое объединение

\newenvironment{definition}[1][]
{
    \par\medskip
    \noindent\textbf{Определение%
    \if\relax\detokenize{#1}\relax
    \else\ (\textit{#1})%
    \fi
    :}\enspace
}
{
    \par\medskip
}

\newenvironment{theorem}[1][]
{
    \par\medskip
    \noindent\textbf{Теорема%
    \if\relax\detokenize{#1}\relax
    \else\ (\textit{#1})%
    \fi
    :}\enspace
}
{
    \par\medskip
}

\newenvironment{remark}[1][]
{
    \par\medskip
    \noindent\textbf{Замечание%
    \if\relax\detokenize{#1}\relax
    \else\ (\textit{#1})%
    \fi
    :}\enspace
}
{
    \par\medskip
}

\newenvironment{example}[1][]
{
    \par\medskip
    \noindent\textbf{Пример%
    \if\relax\detokenize{#1}\relax
    \else\ (\textit{#1})%
    \fi
    :}\enspace
}
{
    \par\medskip
}

